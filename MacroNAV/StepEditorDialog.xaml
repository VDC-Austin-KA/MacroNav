<Window x:Class="MacroNAV.StepEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Step" Width="620" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E2E">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Supplies the dark ComboBox/ComboBoxItem styles; the local
                     style below only coloured the closed box, leaving the
                     dropdown popup white-on-white. -->
                <ResourceDictionary Source="/MacroNAV;component/Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <SolidColorBrush x:Key="BgPanel"    Color="#252535"/>
        <SolidColorBrush x:Key="BgCard"     Color="#2D2D44"/>
        <SolidColorBrush x:Key="BgHover"    Color="#3A3A55"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4F9EF8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#888899"/>
        <SolidColorBrush x:Key="Border"     Color="#3A3A55"/>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="White"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="0,4,0,2"/>
        </Style>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step type -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Step Type" FontWeight="SemiBold"/>
            <ComboBox x:Name="CboStepType" SelectionChanged="CboStepType_SelectionChanged"/>
        </StackPanel>

        <!-- Display name -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Display Name" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtDisplayName"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Description (optional)" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtDescription"/>
        </StackPanel>

        <!-- Parameter schema hint -->
        <Expander Grid.Row="3" Margin="0,0,0,8"
                  Header="Parameter Reference (click to expand)"
                  Foreground="#888899" FontSize="11" IsExpanded="False">
            <Border Background="#1A1A2A" BorderBrush="#3A3A55" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="0,4,0,0">
                <TextBox x:Name="TxtSchemaHint"
                         Background="Transparent" Foreground="#7FBFFF"
                         BorderThickness="0" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="10.5"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         MaxHeight="140"/>
            </Border>
        </Expander>

        <!-- Parameters grid -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="Parameters" FontWeight="SemiBold"/>

            <DataGrid x:Name="ParamGrid" Grid.Row="1"
                      Background="#2D2D44" Foreground="#E8E8F0"
                      BorderBrush="#3A3A55" BorderThickness="1"
                      RowBackground="#2D2D44" AlternatingRowBackground="#252535"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3A3A55"
                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True"
                      HeadersVisibility="Column" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="180"/>
                    <!-- Editable ComboBox: offers the same lists Navisworks and
                         AutoNAV show, but still accepts typed values for names
                         that are not loaded yet. -->
                    <DataGridTemplateColumn Header="Value" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" Margin="6,3"
                                           Foreground="#E8E8F0" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True"
                                          ItemsSource="{Binding Options}"
                                          Text="{Binding Value, Mode=TwoWay,
                                                 UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2"
                       Text="Separate multiple values with | (pipe).  See Parameter Reference above for valid keys."
                       Foreground="#888899" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="ChkEnabled" Grid.Column="0"
                      Content="Step Enabled" IsChecked="True"
                      Foreground="#E8E8F0" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Content="Cancel" Style="{StaticResource BtnBase}"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Grid.Column="3" Content="Save Step" Style="{StaticResource BtnBase}"
                    Background="#2A5EAA" BorderBrush="#4F9EF8" Foreground="White"
                    FontWeight="SemiBold" Click="BtnSave_Click"/>
        </Grid>
    </Grid>
</Window>
