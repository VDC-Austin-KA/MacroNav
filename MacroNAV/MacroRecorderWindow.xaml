<Window x:Class="MacroNAV.MacroRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MacroNAV - Macro Recorder"
        Width="1050" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dark ComboBox/ComboBoxItem styles; the default popup chrome
                     is system white, which made dropdown text unreadable. -->
                <ResourceDictionary Source="/MacroNAV;component/Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <!-- Colors -->
        <SolidColorBrush x:Key="BgDeep"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#252535"/>
        <SolidColorBrush x:Key="BgCard"      Color="#2D2D44"/>
        <SolidColorBrush x:Key="BgHover"     Color="#3A3A55"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#4F9EF8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#50E3A4"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#F85F5F"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#F8C95F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#888899"/>
        <SolidColorBrush x:Key="Border"      Color="#3A3A55"/>

        <!-- Base button style -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"  Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="10,5"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#2A5EAA"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#6B2020"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#1A5E3A"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"    Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="CaretBrush"    Value="White"/>
        </Style>

        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"  Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A66"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="0"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Body -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#181828" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F3AC;" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MacroNAV" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Macro Recorder for Navisworks"
                               FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Recording indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="RecordingDot" Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{StaticResource AccentRed}" Visibility="Collapsed"/>
                    <TextBlock x:Name="RecordingLabel" Text="RECORDING"
                               Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="12"
                               Visibility="Collapsed" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== BODY ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="160"/>  <!-- Macro library -->
                <ColumnDefinition Width="4"/>                   <!-- Splitter -->
                <ColumnDefinition Width="*"/>                   <!-- Editor -->
                <ColumnDefinition Width="4"/>                   <!-- Splitter -->
                <ColumnDefinition Width="190" MinWidth="140"/>  <!-- Capture panel -->
            </Grid.ColumnDefinitions>

            <!-- ── Left: Macro Library ── -->
            <Grid Grid.Column="0" Background="{StaticResource BgPanel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1A1A2A" Padding="8,6">
                    <TextBlock Text="MACRO LIBRARY" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"/>
                </Border>

                <ListBox x:Name="MacroListBox" Grid.Row="1" Margin="0"
                         SelectionChanged="MacroListBox_SelectionChanged"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" BorderBrush="#3A3A55" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{StaticResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="10" Foreground="{StaticResource TextMuted}">
                                        <!-- Run.Text binds TwoWay by default; these are computed
                                             read-only properties, so pin them to OneWay. -->
                                        <Run Text="{Binding EnabledStepCount, Mode=OneWay}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding TotalStepCount, Mode=OneWay}"/>
                                        <Run Text=" steps"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Library buttons -->
                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="6">
                    <Button x:Name="BtnNewMacro" Content="+ New Macro" Style="{StaticResource BtnAccent}"
                            Margin="0,0,0,4" Click="BtnNewMacro_Click"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Import" Style="{StaticResource BtnBase}" Margin="0,0,2,4"
                                Click="BtnImport_Click"/>
                        <Button Grid.Column="1" Content="Export" Style="{StaticResource BtnBase}" Margin="2,0,0,4"
                                Click="BtnExport_Click"/>
                    </Grid>
                    <Button x:Name="BtnDeleteMacro" Content="Delete Macro" Style="{StaticResource BtnRed}"
                            Click="BtnDeleteMacro_Click"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Border}"/>

            <!-- ── Center: Macro Editor ── -->
            <Grid Grid.Column="2" Background="{StaticResource BgDeep}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Macro meta -->
                    <RowDefinition Height="Auto"/>  <!-- Step toolbar -->
                    <RowDefinition Height="*"/>     <!-- Step list -->
                    <RowDefinition Height="Auto"/>  <!-- Playback bar -->
                </Grid.RowDefinitions>

                <!-- Macro meta -->
                <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="10,8" Margin="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Name:" FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtMacroName" Grid.Column="1" Margin="0,0,12,0"
                                 TextChanged="TxtMacroMeta_Changed"/>
                        <Label Grid.Column="2" Content="Description:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtMacroDesc" Grid.Column="3"
                                 TextChanged="TxtMacroMeta_Changed"/>
                    </Grid>
                </Border>

                <!-- Step toolbar -->
                <Border Grid.Row="1" Background="#1A1A2A" Padding="6,5">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="&#x2191; Up"    Style="{StaticResource BtnBase}" Margin="0,0,4,0"
                                Click="BtnMoveUp_Click"/>
                        <Button Content="&#x2193; Down"  Style="{StaticResource BtnBase}" Margin="0,0,4,0"
                                Click="BtnMoveDown_Click"/>
                        <Separator Width="1" Background="{StaticResource Border}" Margin="4,0"/>
                        <Button Content="&#x270E; Edit"  Style="{StaticResource BtnBase}" Margin="0,0,4,0"
                                Click="BtnEditStep_Click"/>
                        <Button Content="+ Insert"        Style="{StaticResource BtnBase}" Margin="0,0,4,0"
                                Click="BtnInsertStep_Click"/>
                        <Button Content="&#x29C9; Dupe"  Style="{StaticResource BtnBase}" Margin="0,0,4,0"
                                Click="BtnDuplicateStep_Click"/>
                        <Button Content="&#x2715; Delete" Style="{StaticResource BtnRed}"  Margin="0,0,4,0"
                                Click="BtnDeleteStep_Click"/>
                        <Separator Width="1" Background="{StaticResource Border}" Margin="4,0"/>
                        <Button Content="Enable All"  Style="{StaticResource BtnBase}" Margin="0,0,4,0"
                                Click="BtnEnableAll_Click"/>
                        <Button Content="Disable All" Style="{StaticResource BtnBase}"
                                Click="BtnDisableAll_Click"/>
                    </StackPanel>
                </Border>

                <!-- Step list -->
                <ListBox x:Name="StepListBox" Grid.Row="2" Margin="0"
                         SelectionChanged="StepListBox_SelectionChanged"
                         MouseDoubleClick="StepListBox_DoubleClick"
                         BorderThickness="0" VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>   <!-- step # -->
                                    <ColumnDefinition Width="24"/>   <!-- icon -->
                                    <ColumnDefinition Width="30"/>   <!-- checkbox -->
                                    <ColumnDefinition Width="*"/>    <!-- name + params -->
                                </Grid.ColumnDefinitions>

                                <!-- Step number -->
                                <Border Background="#1A1A2A" Margin="0,0,1,0">
                                    <TextBlock x:Name="StepNumLabel"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="10" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Padding="4"/>
                                </Border>

                                <!-- Icon -->
                                <TextBlock Grid.Column="1" Text="{Binding StepTypeIcon}"
                                           FontSize="13" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Padding="2"/>

                                <!-- Enable toggle -->
                                <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Checked="StepEnabled_Changed" Unchecked="StepEnabled_Changed"/>

                                <!-- Display name + params -->
                                <StackPanel Grid.Column="3" Margin="6,4">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ParamSummary}" FontSize="10"
                                               Foreground="{StaticResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Playback bar -->
                <Border Grid.Row="3" Background="#181828" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnRecord" Content="&#x23FA; Record"
                                Style="{StaticResource BtnRed}" Width="90" Margin="0,0,6,0"
                                Click="BtnRecord_Click"/>
                        <Button x:Name="BtnStopRecord" Grid.Column="1" Content="&#x25A0; Stop"
                                Style="{StaticResource BtnBase}" Width="80" Margin="0,0,6,0"
                                IsEnabled="False" Click="BtnStopRecord_Click"/>
                        <Separator Grid.Column="2" Width="1" Background="{StaticResource Border}" Margin="6,0"/>
                        <Button x:Name="BtnPlay" Grid.Column="3" HorizontalAlignment="Left"
                                Content="&#x25B6; Play Macro" Style="{StaticResource BtnGreen}"
                                Width="110" Margin="0,0,6,0" Click="BtnPlay_Click"/>
                        <Button x:Name="BtnStopPlay" Grid.Column="4" Content="&#x23F9; Stop"
                                Style="{StaticResource BtnBase}" Width="80"
                                IsEnabled="False" Click="BtnStopPlay_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Border}"/>

            <!-- ── Right: Quick Capture Panel ── -->
            <Grid Grid.Column="4" Background="{StaticResource BgPanel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1A1A2A" Padding="8,6">
                    <TextBlock Text="QUICK CAPTURE" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">

                        <TextBlock Text="Clash Detective" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,8,0,4"/>

                        <ComboBox x:Name="CboClashTests" Margin="0,0,0,4"
                                  Background="{StaticResource BgCard}"
                                  Foreground="{StaticResource TextPrimary}"
                                  DropDownOpened="CboClashTests_DropDownOpened"
                                  ToolTip="Select a clash test to capture"/>

                        <Button Content="Capture Test Config" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureClashConfig_Click"
                                ToolTip="Record the selected clash test's settings"/>
                        <Button Content="Capture Run Test" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureRunTest_Click"
                                ToolTip="Record a step to run the selected test"/>
                        <Button Content="Run All Tests" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureRunAll_Click"/>

                        <Separator Margin="0,8" Background="{StaticResource Border}"/>

                        <TextBlock Text="Navigation" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,4"/>

                        <Button Content="Capture Current View" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureCurrentView_Click"
                                ToolTip="Record the current camera viewpoint"/>

                        <ComboBox x:Name="CboViewpoints" Margin="0,0,0,4"
                                  Background="{StaticResource BgCard}"
                                  Foreground="{StaticResource TextPrimary}"
                                  DropDownOpened="CboViewpoints_DropDownOpened"
                                  ToolTip="Select a saved viewpoint"/>
                        <Button Content="Capture Saved Viewpoint" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureSavedViewpoint_Click"/>

                        <Separator Margin="0,8" Background="{StaticResource Border}"/>

                        <TextBlock Text="Selection Sets" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,4"/>

                        <ComboBox x:Name="CboSelectionSets" Margin="0,0,0,4"
                                  Background="{StaticResource BgCard}"
                                  Foreground="{StaticResource TextPrimary}"
                                  DropDownOpened="CboSelectionSets_DropDownOpened"
                                  ToolTip="Select a selection set"/>
                        <Button Content="Capture Activate Set" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureSelectionSet_Click"/>

                        <Separator Margin="0,8" Background="{StaticResource Border}"/>

                        <TextBlock Text="Misc" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,4"/>

                        <TextBox x:Name="TxtComment" Margin="0,0,0,4"
                                 Tag="Enter comment text..."
                                 ToolTip="Add a comment step"/>
                        <Button Content="Add Comment" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnAddComment_Click"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDelayMs" Text="1000" ToolTip="Delay in milliseconds"/>
                            <Label Grid.Column="1" Content="ms" Padding="4,0,0,0"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="Add Delay" Style="{StaticResource BtnBase}"
                                Click="BtnAddDelay_Click"/>

                        <Separator Margin="0,8" Background="{StaticResource Border}"/>

                        <TextBlock Text="AutoNAV" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,4"/>
                        <Button Content="AutoNAV: Search Sets" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureAutoNavSS_Click"
                                ToolTip="Insert an AutoNAV search set generation step"/>
                        <Button Content="AutoNAV: Clash Tests" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureAutoNavCT_Click"
                                ToolTip="Insert an AutoNAV clash test generation step"/>
                        <Button Content="AutoNAV: Run All Clash Tests" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,4" Click="BtnCaptureAutoNavRunAll_Click"
                                ToolTip="Run every clash test via AutoNAV, without a grouping pass"/>
                        <Button Content="AutoNAV: Group by Walls/Floors" Style="{StaticResource BtnBase}"
                                Margin="0,0,0,8" Click="BtnCaptureAutoNavWallsFloors_Click"
                                ToolTip="Group every test by walls and floors"/>

                        <!-- Rename: applies a template through AutoNAV's grouper
                             directly, so replay skips loading its rename tree. -->
                        <TextBlock Text="Rename clash groups" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CboRenameTemplate" Margin="0,0,0,4"
                                  ToolTip="Naming template applied to clash groups"/>
                        <TextBox x:Name="TxtRenameTest" Margin="0,0,0,4" Text="*"
                                 ToolTip="Clash test to rename, or * for every test"/>
                        <Button Content="AutoNAV: Rename Groups" Style="{StaticResource BtnAccent}"
                                Click="BtnCaptureAutoNavRename_Click"
                                ToolTip="Insert a rename step using the template above"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2" Background="#181828" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextMuted}"
                           FontSize="11" VerticalAlignment="Center"
                           Text="Ready"/>
                <TextBlock Grid.Column="1" x:Name="StepCountText"
                           Foreground="{StaticResource TextMuted}" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
