<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" DefaultTargets="Build"
         xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Release-NW2025</Configuration>
    <Platform      Condition=" '$(Platform)'       == '' ">x64</Platform>
    <ProjectGuid>{A1B2C3D4-0003-0003-0003-A1B2C3D40003}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>MacroNAVTests.UiSmoke</RootNamespace>
    <AssemblyName>MacroNAVUiSmoke</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>9.0</LangVersion>
    <OutputPath>bin\</OutputPath>
    <DefineConstants>TRACE;NW2025</DefineConstants>
    <NWPath>C:\Program Files\Autodesk\Navisworks Manage 2025\</NWPath>
    <MacroNAVOut>$(MSBuildThisFileDirectory)..\..\MacroNAV\bin\Release-NW2025\</MacroNAVOut>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml" />
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System.Xaml" />
    <Reference Include="Autodesk.Navisworks.Api">
      <HintPath>$(NWPath)Autodesk.Navisworks.Api.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="MacroNAV">
      <HintPath>$(MacroNAVOut)MacroNAV.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

</Project>
